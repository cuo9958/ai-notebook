{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main",
    "debug-log-window"
  ],
  "permissions": [
    "core:default",
    "core:app:allow-app-hide",
    "core:app:allow-app-show",
    "core:path:default",
    "core:menu:default",
    "http:default",
    "dialog:allow-open",
    {
      "identifier": "fs:scope",
      "allow": [
        {
          "path": "$APPDATA/**"
        },
        {
          "path": "$APPCONFIG/**"
        },
        {
          "path": "$APPLOCALDATA/**"
        },
        {
          "path": "$DOCUMENT/**"
        },
        {
          "path": "$DESKTOP/**"
        },
        {
          "path": "$DOWNLOAD/**"
        },
        {
          "path": "$HOME/**"
        },
        {
          "path": "$PICTURES/**"
        },
        {
          "path": "**"
        }
      ]
    },
     "fs:default",
    "fs:allow-app-read",
    "fs:allow-app-write",
    "fs:allow-app-meta",
    "fs:scope-app",
    "fs:scope-app-index",
    "fs:allow-appcache-read",
    "fs:allow-appcache-write",
    "fs:allow-appcache-meta",
    "fs:scope-appcache",
    "fs:scope-appcache-index",
    "fs:allow-appconfig-read",
    "fs:allow-appconfig-write",
    "fs:allow-appconfig-meta",
    "fs:scope-appconfig",
    "fs:scope-appconfig-index",
    "fs:allow-appdata-read",
    "fs:allow-appdata-write",
    "fs:allow-appdata-meta",
    "fs:scope-appdata",
    "fs:scope-appdata-index",
    "fs:allow-applog-read",
    "fs:allow-applog-write",
    "fs:allow-applog-meta",
    "fs:scope-applog",
    "fs:scope-applog-index",
    "fs:allow-applocaldata-read",
    "fs:allow-applocaldata-write",
    "fs:allow-applocaldata-meta",
    "fs:scope-applocaldata",
    "fs:scope-applocaldata-index",
    "fs:allow-cache-read",
    "fs:allow-cache-write",
    "fs:allow-cache-meta",
    "fs:scope-cache",
    "fs:scope-cache-index",
    "fs:allow-read",
    "fs:allow-mkdir",
    "fs:allow-read-dir",
    "fs:allow-read-file",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-remove",
    "fs:allow-rename",
    "fs:allow-write",
    "fs:allow-exists",
    "dialog:default"
  ]
}
